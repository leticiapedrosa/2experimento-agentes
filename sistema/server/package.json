  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.8.1",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "@types/express": "^5.0.3",
    "@types/cors": "^2.8.19",
    "ts-node": "^10.9.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}

